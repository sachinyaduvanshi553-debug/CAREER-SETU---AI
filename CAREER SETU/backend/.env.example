# =====================================================
# Career Setu Backend - Environment Variables
# =====================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to git (it's in .gitignore).

# --- Gemini AI API Key (Required) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- CORS Allowed Origins (Recommended for production) ---
# Comma-separated list of allowed frontend URLs.
# Example: https://your-frontend.onrender.com,https://yourdomain.com
# Leave as "*" to allow all origins (dev only — disables credentials).
ALLOWED_ORIGINS=*

# --- Server Port (Optional) ---
# Render automatically sets this. Only needed for local overrides.
# PORT=8000
